{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "**/*",
      "!**/.umi",
      "!**/.umi-production",
      "!**/.umi-test",
      "!**/.umi-test-production",
      "!**/src/services",
      "!**/mock",
      "!**/dist",
      "!**/server",
      "!**/public",
      "!**/coverage",
      "!**/node_modules",
      "!scripts",
      "!biome.json",
      "!tailwind.css",
      "!**/.worktrees"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space"
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noExplicitAny": "off",
        "noUnknownAtRules": "off",
        "noConsole": "warn"
      },
      "correctness": {
        "useUniqueElementIds": "off",
        "useExhaustiveDependencies": "warn",
        "noUnusedImports": "error"
      },
      "a11y": {
        "noStaticElementInteractions": "off",
        "useValidAnchor": "off",
        "useKeyWithClickEvents": "off"
      }
    }
  },
  "javascript": {
    "jsxRuntime": "transparent",
    "formatter": {
      "quoteStyle": "single"
    }
  }
}
